# ===========================
# Backend (.env in /backend)
# ===========================

# Server port (default: 3001)
PORT=3001

# CORS origin for frontend (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# Google Maps Geocoding API Key
# Get from: https://console.cloud.google.com/
# Required APIs: Geocoding API, Maps JavaScript API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Twitter/X Bearer Token
# Get from: https://developer.twitter.com/
# Required: Basic access (free tier supports recent search)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Mock modes (set to false to use real APIs)
MOCK_SCRAPERS=true
MOCK_TWITTER=true
MOCK_GEOCODING=true

# ===========================
# Frontend (.env in /frontend)
# ===========================

# Backend API URL
VITE_API_URL=http://localhost:3001

# Google Maps JavaScript API Key (can be same as above)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
